ENV=dev

# book lookup
HARDCOVER_API_TOKEN=        # from hardcover.app/account/api (value includes "Bearer ")
GOOGLE_BOOKS_API_KEY=       # optional; keyless works but is throttled

# trending (Exa /answer; needed for real results — `marty trending --source fake` works without it)
EXA_API_KEY=

# optional: override the SQLite cache location (default ~/.local/share/marty/cache.db)
# MARTY_CACHE=
